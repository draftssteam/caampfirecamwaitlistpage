<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Campfire Cam — Sold Out for Summer</title>
  <meta name="description" content="Campfire Cam is sold out for summer. Join the waitlist to be first to know when we're back with something even better.">

  <!-- Open Graph (for sharing on Facebook, iMessage, etc.) -->
  <meta property="og:title" content="Campfire Cam — Sold Out for Summer">
  <meta property="og:description" content="We sold out. Something better is coming. Join the waitlist.">
  <meta property="og:image" content="https://campfirecam.com/og-image.jpg">
  <!-- SWAP: Replace og:image URL with a real hosted image -->
  <meta property="og:url" content="https://campfirecam.com">
  <meta property="og:type" content="website">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Campfire Cam — Sold Out for Summer">
  <meta name="twitter:description" content="We sold out. Something better is coming.">
  <meta name="twitter:image" content="https://campfirecam.com/og-image.jpg">

  <!-- <link rel="icon" href="favicon.ico" type="image/x-icon"> -->

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #FAF7F2;
      --ink: #1A1A18;
      --sienna: #A0522D;
      --sand: #D4A882;
      --parchment: #EFEAE0;
      --muted: #6B6357;
      --border: #D5CDBD;
      --dark-bg: #1A1A18;
      --dark-card: #2E2D29;
      --dark-text: #A09880;
      --green-badge: #D6E8C8;
      --green-text: #3B6D11;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: "DM Sans", sans-serif;
      background: var(--cream);
      color: var(--ink);
      line-height: 1.5;
    }

    .container { width: min(1120px, 92vw); margin: 0 auto; }

    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: color-mix(in srgb, var(--cream) 90%, transparent);
      border-bottom: 0.5px solid var(--border);
      backdrop-filter: blur(8px);
      padding: 18px 40px;
      display: flex; justify-content: space-between; align-items: center;
      transition: box-shadow 0.3s ease;
    }
    .navbar.scrolled { box-shadow: 0 6px 18px rgba(26, 26, 24, 0.08); }
    .brand { font-family: "Playfair Display", serif; font-size: 16px; }
    .sold-pill {
      font-size: 11px; text-transform: uppercase; color: var(--muted);
      background: var(--parchment); border-radius: 20px; padding: 7px 12px;
      letter-spacing: 0.06em;
    }

    section { padding: 88px 0; }
    #hero { padding-top: 140px; min-height: 96vh; text-align: center; display: flex; align-items: center; }
    .hero-inner { width: min(760px, 92vw); margin: 0 auto; }
    .hero-badge { display: inline-block; background: var(--green-badge); color: var(--green-text); border-radius: 20px; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; padding: 8px 12px; }
    .hero-title { font-family: "Playfair Display", serif; font-size: 58px; line-height: 1.15; margin: 22px 0 16px; }
    .hero-title span { display: block; will-change: transform, opacity; }
    .hero-title em { color: var(--sienna); font-style: italic; }
    .hero-copy { max-width: 500px; margin: 0 auto; font-size: 17px; font-weight: 300; color: var(--muted); }
    .hero-actions { margin-top: 28px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn { font: 400 14px "DM Sans", sans-serif; padding: 12px 24px; border-radius: 8px; border: 0.5px solid transparent; cursor: pointer; }
    .btn-primary { background: var(--ink); color: var(--cream); }
    .btn-ghost { background: transparent; color: var(--ink); border-color: var(--border); }
    .scroll-indicator { margin-top: 42px; color: var(--muted); font-size: 20px; }

    #gallery .label, #waitlist .label { font-size: 11px; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; }
    h2 { font-family: "Playfair Display", serif; font-size: 40px; margin: 12px 0 34px; }
    .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; grid-auto-rows: 190px; }
    .image-card { position: relative; border-radius: 10px; overflow: hidden; will-change: transform, opacity; }
    .image-card.tall { grid-row: span 2; }
    .image-card img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s ease; display: block; }
    .image-card:hover img { transform: scale(1.02); }
    .gallery-image:hover { cursor: crosshair; }
    .overlay {
      position: absolute; left: 10px; bottom: 10px; font-size: 12px; color: #fff;
      background: rgba(0,0,0,.35); border-radius: 14px; padding: 5px 10px;
      opacity: 0; transform: translateY(8px); transition: .25s ease;
    }
    .image-card:hover .overlay { opacity: 1; transform: translateY(0); }
    .gallery-caption { text-align: center; font-size: 12px; color: var(--muted); margin-top: 18px; }

    .story-wrap { display: grid; grid-template-columns: 1.3fr 1fr; gap: 32px; align-items: start; }
    .story-wrap h3 { font: 400 26px "Playfair Display", serif; margin: 0 0 16px; }
    .story-wrap p { font-size: 14px; font-weight: 300; color: var(--muted); line-height: 1.75; margin: 0; }
    .stat-col { display: grid; gap: 14px; }
    .stat-card { background: var(--parchment); border-radius: 10px; padding: 20px; }
    .stat-big { font: 400 32px "Playfair Display", serif; color: var(--sienna); margin: 0 0 8px; }
    .stat-small { font-size: 12px; color: var(--muted); margin: 0; }

    .video-wrap { text-align: center; }
    .video-box { max-width: 760px; margin: 20px auto 0; border-radius: 16px; background: var(--dark-bg); overflow: hidden; padding: 0; position: relative; }
    .video-box video { width: 100%; display: block; }
    .play-btn {
      position: absolute; inset: 0; margin: auto; width: 74px; height: 74px; border-radius: 50%; border: 0;
      background: rgba(250,247,242,0.2); color: var(--cream); font-size: 28px; cursor: pointer;
      backdrop-filter: blur(3px);
    }

    .teaser-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .teaser-card { background: var(--parchment); border-radius: 12px; padding: 24px; will-change: transform, opacity; }
    .teaser-badge { display: inline-block; font-size: 10px; text-transform: uppercase; border-radius: 20px; background: var(--ink); color: var(--sand); padding: 5px 10px; letter-spacing: .08em; }
    .teaser-card h4 { font: 400 24px "Playfair Display", serif; margin: 14px 0 8px; }
    .teaser-card p { margin: 0; color: var(--muted); font-size: 14px; font-weight: 300; }

    #waitlist {
      background: var(--dark-bg);
      color: var(--cream);
      position: relative;
      overflow: hidden;
    }
    #waitlist::before {
      content: "";
      position: absolute; inset: 0;
      background-image: radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px);
      background-size: 3px 3px;
      pointer-events: none;
    }
    .waitlist-inner { position: relative; z-index: 1; max-width: 600px; margin: 0 auto; text-align: center; }
    .waitlist-inner .label { color: var(--sand); }
    .wait-title { font-family: "Playfair Display", serif; font-size: 34px; margin: 10px 0 14px; }
    .wait-title span { display: inline-block; opacity: 0; transform: translateY(14px); }
    .wait-title em { color: var(--sand); font-style: italic; }
    .wait-copy { color: var(--dark-text); font-size: 14px; font-weight: 300; margin-bottom: 24px; }
    .wait-form { display: flex; gap: 10px; }
    .wait-form input {
      flex: 1; background: var(--dark-card); border: .5px solid #4A4840; border-radius: 8px;
      padding: 14px 18px; color: #fff; font-size: 14px;
    }
    .wait-form button { background: var(--sand); color: var(--ink); border: 0; border-radius: 8px; padding: 14px 24px; font-size: 14px; font-weight: 500; cursor: pointer; transition: filter .2s ease; }
    .wait-form button:hover { filter: brightness(0.9); }
    .error { color: #ff7a7a; font-size: 12px; margin-top: 8px; text-align: left; }
    .success { display: none; margin-top: 10px; }
    .success-icon { width: 40px; height: 40px; border: 1px solid var(--sand); color: var(--sand); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 10px; }
    .fine-print { margin-top: 12px; color: var(--dark-text); font-size: 11px; }

    footer { border-top: .5px solid var(--border); padding: 28px 0 34px; }
    .footer-wrap { display: flex; justify-content: space-between; gap: 16px; align-items: start; }
    .footer-brand { font-family: "Playfair Display", serif; font-size: 14px; color: var(--muted); margin: 0 0 4px; }
    .footer-copy { font-size: 11px; color: var(--border); margin: 0; }
    .footer-links { display: flex; gap: 16px; flex-wrap: wrap; }
    .footer-links a { color: var(--muted); font-size: 12px; text-decoration: none; }
    .footer-links a:hover { text-decoration: underline; }

    @media (max-width: 768px) {
      .navbar { padding: 16px 20px; }
      .hero-title { font-size: 36px; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .story-wrap, .teaser-grid { grid-template-columns: 1fr; }
      .wait-form { flex-direction: column; }
      .wait-form input, .wait-form button { width: 100%; }
    }

    @media (max-width: 480px) {
      #hero { padding-top: 120px; }
      .hero-title { font-size: 34px; }
      h2 { font-size: 32px; }
      .gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 240px; }
      .image-card.tall { grid-row: span 1; }
      .footer-wrap { flex-direction: column; align-items: center; text-align: center; }
      .footer-links { justify-content: center; }
    }
  </style>
</head>
<body>
  <nav class="navbar" id="navbar">
    <div class="brand">Campfire Cam</div>
    <div class="sold-pill">Sold Out · Back Soon</div>
  </nav>

  <section id="hero">
    <div class="hero-inner">
      <div class="hero-badge">✦ Summer 2025</div>
      <h1 class="hero-title"><span>Gone for summer.</span><span><em>Back even better.</em></span></h1>
      <p class="hero-copy">Every camera found a home. Every memory got made. We sold out — and we couldn't be more grateful. Something new is on its way. Get on the list to hear first.</p>
      <div class="hero-actions">
        <button class="btn btn-primary" id="join-waitlist-btn">Join the Waitlist</button>
        <button class="btn btn-ghost" id="see-memories-btn">See the memories ↓</button>
      </div>
      <div class="scroll-indicator" id="scroll-indicator">↓</div>
    </div>
  </section>

  <section id="gallery">
    <div class="container">
      <div class="label">Captured by you</div>
      <h2>Real moments. Real memories.</h2>
      <!-- SWAP: Replace picsum.photos URLs below with real customer photos -->
      <div class="gallery-grid">
        <article class="image-card tall"><img class="gallery-image" loading="lazy" src="https://picsum.photos/seed/campfire1/600/900" alt="Lake day memory"><span class="overlay">lake day</span></article>
        <article class="image-card"><img class="gallery-image" loading="lazy" src="https://picsum.photos/seed/campfire2/600/400" alt="Road trip memory"><span class="overlay">road trip</span></article>
        <article class="image-card"><img class="gallery-image" loading="lazy" src="https://picsum.photos/seed/campfire3/600/400" alt="Campsite memory"><span class="overlay">golden hour</span></article>
        <article class="image-card tall"><img class="gallery-image" loading="lazy" src="https://picsum.photos/seed/campfire4/600/900" alt="Mountain hike memory"><span class="overlay">hike morning</span></article>
        <article class="image-card"><img class="gallery-image" loading="lazy" src="https://picsum.photos/seed/campfire5/600/400" alt="Beach picnic memory"><span class="overlay">beach picnic</span></article>
        <article class="image-card"><img class="gallery-image" loading="lazy" src="https://picsum.photos/seed/campfire6/600/400" alt="City stroll memory"><span class="overlay">city dusk</span></article>
      </div>
      <p class="gallery-caption">Photos taken by our community · 1,000+ memories made</p>
    </div>
  </section>

  <section id="story">
    <div class="container story-wrap">
      <div class="story-col-left">
        <h3>You validated everything we believed in.</h3>
        <p>We built Campfire Cam because we missed the feeling of just taking a photo — no screens, no previews, no second-guessing the shot. You felt it too. Every single camera sold. Now we're taking everything we learned and building what comes next. It's going to be worth the wait.</p>
      </div>
      <div class="stat-col">
        <article class="stat-card"><p class="stat-big">Sold Out</p><p class="stat-small">Every camera found a home</p></article>
        <article class="stat-card"><p class="stat-big">1,000+</p><p class="stat-small">Photos captured without a screen</p></article>
      </div>
    </div>
  </section>

  <section id="video-placeholder">
    <div class="container video-wrap">
      <h2>See what a screen-free summer looks like</h2>
      <div class="video-box" id="video-box">
        <!-- SWAP: Add real video URL in the video section -->
        <video id="campfire-video" controls preload="none">
          <!-- ADD VIDEO URL HERE -->
        </video>
        <button class="play-btn" id="play-video" aria-label="Play video">▶</button>
      </div>
    </div>
  </section>

  <section id="teaser">
    <div class="container teaser-grid">
      <article class="teaser-card"><span class="teaser-badge">Coming Soon</span><h4>A new version</h4><p>We're building something that takes everything people loved and makes it even more intentional. More on this soon.</p></article>
      <article class="teaser-card"><span class="teaser-badge">Waitlist Only</span><h4>Early access</h4><p>Waitlist members get first look, early pricing, and a say in what gets built. No spam, ever.</p></article>
      <article class="teaser-card"><span class="teaser-badge">Stay Close</span><h4>Community drops</h4><p>UGC features, behind-the-scenes content, and the story of building v2 — shared with the people who got us here.</p></article>
    </div>
  </section>

  <section id="waitlist">
    <div class="container waitlist-inner" id="waitlist-section">
      <div class="label">Get in early</div>
      <h2 class="wait-title" id="waitlist-heading">Be first. <em>Join the waitlist.</em></h2>
      <p class="wait-copy">No selling right now — just building something worth waiting for. Drop your email and we'll reach out when the time is right.</p>
      <!-- SWAP: Add Mailchimp form action URL in the waitlist form -->
      <form class="wait-form" id="waitlist-form" novalidate>
        <input id="email" type="email" placeholder="your@email.com" aria-label="Email address">
        <button type="submit">Join the Waitlist</button>
      </form>
      <div class="error" id="form-error" role="alert"></div>
      <div class="success" id="form-success">
        <div class="success-icon">✓</div>
        <div>You're on the list! We'll be in touch soon.</div>
      </div>
      <p class="fine-print">No spam. One email when it matters. Unsubscribe anytime.</p>
    </div>
  </section>

  <footer id="footer">
    <div class="container footer-wrap">
      <div>
        <p class="footer-brand">Campfire Cam</p>
        <p class="footer-copy">© 2025 · Made for real moments</p>
      </div>
      <!-- SWAP: Replace Instagram/TikTok links with real social handles -->
      <!-- SWAP: Replace mailto: email with real contact email -->
      <div class="footer-links">
        <a href="https://instagram.com/campfirecam" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://tiktok.com/@campfirecam" target="_blank" rel="noopener noreferrer">TikTok</a>
        <a href="mailto:hello@campfirecam.com" target="_blank" rel="noopener noreferrer">Contact</a>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <script>
    // If user goes to /products or /shop, send them to the homepage
    // If using Shopify: set up URL redirects in Shopify Admin > Navigation > URL Redirects
    const path = window.location.pathname;
    if (path.includes('/products') || path.includes('/shop') || path.includes('/cart')) {
      window.location.replace('/');
    }

    gsap.registerPlugin(ScrollTrigger);

    window.addEventListener('scroll', () => {
      document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 50);
      const heroHeight = document.getElementById('hero').offsetHeight;
      if (window.scrollY > heroHeight * 0.55) {
        document.getElementById('scroll-indicator').style.opacity = '0';
      } else {
        document.getElementById('scroll-indicator').style.opacity = '1';
      }
    });

    document.querySelector('#join-waitlist-btn').addEventListener('click', function() {
      document.querySelector('#waitlist-section').scrollIntoView({ behavior: 'smooth' });
    });
    document.querySelector('#see-memories-btn').addEventListener('click', function() {
      document.querySelector('#gallery').scrollIntoView({ behavior: 'smooth' });
    });

    gsap.from('.hero-badge', { opacity: 0, y: 20, duration: 0.6, ease: 'power2.out' });
    gsap.from('.hero-title span', { opacity: 0, y: 30, duration: 0.7, stagger: 0.2, delay: 0.2, ease: 'power2.out' });
    gsap.from('.hero-copy', { opacity: 0, duration: 0.6, delay: 0.6 });
    gsap.from('.hero-actions', { opacity: 0, duration: 0.6, delay: 0.8 });
    gsap.to('.scroll-indicator', { y: 8, repeat: -1, yoyo: true, duration: 0.8, ease: 'power1.inOut' });

    gsap.from('.image-card', {
      scrollTrigger: { trigger: '#gallery', start: 'top 75%' },
      opacity: 0, y: 40, duration: 0.8, stagger: 0.1, ease: 'power2.out'
    });

    gsap.from('.story-col-left', {
      scrollTrigger: { trigger: '#story', start: 'top 75%' },
      x: -50, opacity: 0, duration: 0.8, ease: 'power2.out'
    });
    gsap.from('.stat-col', {
      scrollTrigger: { trigger: '#story', start: 'top 75%' },
      x: 50, opacity: 0, duration: 0.8, ease: 'power2.out'
    });

    gsap.from('.video-box', {
      scrollTrigger: { trigger: '#video-placeholder', start: 'top 80%' },
      opacity: 0, scale: 0.95, duration: 0.8, ease: 'power2.out'
    });

    gsap.from('.teaser-card', {
      scrollTrigger: { trigger: '#teaser', start: 'top 80%' },
      opacity: 0, y: 40, duration: 0.8, stagger: 0.15, ease: 'power2.out'
    });

    gsap.from('#waitlist', {
      scrollTrigger: { trigger: '#waitlist', start: 'top 80%' },
      opacity: 0, duration: 0.8
    });

    const heading = document.getElementById('waitlist-heading');
    const words = heading.innerHTML.split(' ').map(word => `<span>${word}</span>`).join(' ');
    heading.innerHTML = words;
    gsap.to('#waitlist-heading span', {
      scrollTrigger: { trigger: '#waitlist', start: 'top 75%' },
      opacity: 1, y: 0, stagger: 0.08, duration: 0.5, ease: 'power2.out'
    });

    const form = document.getElementById('waitlist-form');
    const input = document.getElementById('email');
    const error = document.getElementById('form-error');
    const success = document.getElementById('form-success');

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = input.value.trim();
      const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

      if (!isValid) {
        error.textContent = 'Please enter a valid email address.';
        return;
      }

      // REPLACE THIS URL WITH YOUR MAILCHIMP FORM ACTION URL
      error.textContent = '';
      form.style.display = 'none';
      success.style.display = 'block';
    });

    document.getElementById('play-video').addEventListener('click', () => {
      const video = document.getElementById('campfire-video');
      video.play();
      document.getElementById('play-video').style.display = 'none';
    });
  </script>
</body>
</html>
